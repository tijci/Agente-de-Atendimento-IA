# Copie para .env e preencha os valores reais

PORT=5173

# OpenAI — agente conversacional Ana
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPEN_AI_TEMPERATURE=0.1

# Neppo — login WebSocket + API REST
NEPPO_API_URL=https://api.neppo.com.br
NEPPO_CUSTOMER_KEY=
NEPPO_CUSTOMER_SECRET=
NEPPO_USERNAME=
NEPPO_PASSWORD=
NEPPO_GROUP_NAME=
NEPPO_USER_ID=
NEPPO_GROUP_CONF_ID=

# Groq — transcrição de áudios WhatsApp
GROQ_API_KEY=

# CRM KSI (integração futura)
KSI_API_URL=
KSI_API_TOKEN=

# Envio humanizado — múltiplas bolhas no WhatsApp
MESSAGE_SPLIT_ENABLED=true
# false = 1 bolha por parágrafo/bloco; true = mescla aleatória de blocos adjacentes
MESSAGE_SPLIT_RANDOMIZE=false
MESSAGE_DELAY_MIN_MS=1000
MESSAGE_DELAY_MAX_MS=5000

# Worker — busca por imagem (opcional)
IMAGE_EXACT_THRESHOLD=0.70
IMAGE_CANDIDATE_THRESHOLD=0.58
IMAGE_EXACT_MARGIN=0.04
OCR_TEXT_CANDIDATE_THRESHOLD=0.35
